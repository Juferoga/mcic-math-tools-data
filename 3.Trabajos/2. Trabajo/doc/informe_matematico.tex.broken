\PY{k}{def}\PY{+w}{ }\PY{n+nf}{erlang\PYZus{}b\PYZus{}recursive}\PY{p}{(}\PY{n}{A}\PY{p}{:} \PY{n+nb}{float}\PY{p}{,} \PY{n}{k}\PY{p}{:} \PY{n+nb}{int}\PY{p}{)} \PY{o}{\PYZhy{}}\PY{o}{\PYZgt{}} \PY{n+nb}{float}\PY{p}{:}
